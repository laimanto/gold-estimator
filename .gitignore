# Ignore everything by default
*

# Keep git metadata
!.gitignore

# Keep only the published dashboards
# Stable path (always the current version): /dashboard.html
!/dashboard.html
# Root index (same content) so the bare Pages URL works: /index.html
!/index.html
!gold_estimator_v3/
!gold_estimator_v3/Doc/
!gold_estimator_v3/Doc/dashboard.html

# Keep the GitHub Actions Pages deploy workflow
!.github/
!.github/workflows/
!.github/workflows/pages.yml
